# ── Local development (docker compose) ───────────────────────────────
# Copy to .env and adjust as needed. docker compose reads .env by default.

PORT=8080

# Cameras: comma-separated camera_id=rtsp_url pairs
CAMERA_URLS=test=rtsp://mediamtx:8554/test

# S3 storage (MinIO local / Cloudflare R2 production)
# ── MinIO (local dev) ─────────────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_BUCKET=camaron
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_PATH_STYLE=true

# ── Cloudflare R2 (production) ───────────────────────────────────────
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_BUCKET=camaron
# S3_ACCESS_KEY_ID=<r2_access_key>
# S3_SECRET_ACCESS_KEY=<r2_secret_key>
# S3_REGION=auto
# S3_USE_PATH_STYLE=false

# Recording
RECORDING_DIR=/tmp/camaron/recordings
SEGMENT_FRAMES=25
FPS_LIMIT=5
UPLOAD_WORKERS=10
